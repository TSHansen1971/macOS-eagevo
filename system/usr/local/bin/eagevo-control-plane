#!/usr/bin/env python3
import argparse
import hashlib
import json
import subprocess
import sys
from pathlib import Path

USR_INDEX = Path("/usr/local/lib/eagevo/control-plane-index.json")
LIB_INDEX = Path("/Library/Eagevo/control-plane-index.json")

REQUIRED_FILES = [
    Path("/usr/local/lib/eagevo/foundation-contract.json"),
    Path("/usr/local/lib/eagevo/audit/audit-core-contract.json"),
    Path("/usr/local/lib/eagevo/status-core-contract.json"),
    Path("/usr/local/lib/eagevo/baseline-manifest.json"),
    Path("/Library/Eagevo/baseline-manifest.json"),
    USR_INDEX,
    LIB_INDEX,
]

REQUIRED_EXECUTABLES = [
    Path("/usr/local/bin/eagevo-status"),
    Path("/usr/local/bin/eagevo-baseline"),
    Path("/usr/local/bin/eagevo-audit"),
    Path("/usr/local/bin/eagevo-control-plane"),
]

FORBIDDEN_GLOBS = [
    "/Library/LaunchDaemons/*eagevo*",
    "/Library/LaunchAgents/*eagevo*",
    str(Path.home() / "Library/LaunchAgents/*eagevo*"),
]

def sha256(path):
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()

def load_index():
    return json.loads(USR_INDEX.read_text(encoding="utf-8"))

def verify(print_output=True):
    fail = False

    if print_output:
        print("== eagevo-control-plane ==")
        print("mode: read-only-index")
        print("enforcement: disabled")
        print("launchd: disabled")
        print()

    for path in REQUIRED_FILES:
        if path.exists():
            if print_output:
                print(f"OK: exists: {path}")
        else:
            fail = True
            if print_output:
                print(f"FAIL: missing: {path}")

    for path in REQUIRED_EXECUTABLES:
        if path.exists() and path.is_file() and path.stat().st_mode & 0o111:
            if print_output:
                print(f"OK: executable: {path}")
        else:
            fail = True
            if print_output:
                print(f"FAIL: missing_or_not_executable: {path}")

    if USR_INDEX.exists() and LIB_INDEX.exists():
        usr_sha = sha256(USR_INDEX)
        lib_sha = sha256(LIB_INDEX)
        if usr_sha == lib_sha:
            if print_output:
                print(f"OK: control_plane_index_sha256: {usr_sha}")
        else:
            fail = True
            if print_output:
                print(f"FAIL: control_plane_index_sha_mismatch: {usr_sha} != {lib_sha}")

    baseline_usr = Path("/usr/local/lib/eagevo/baseline-manifest.json")
    baseline_lib = Path("/Library/Eagevo/baseline-manifest.json")
    if baseline_usr.exists() and baseline_lib.exists():
        baseline_usr_sha = sha256(baseline_usr)
        baseline_lib_sha = sha256(baseline_lib)
        if baseline_usr_sha == baseline_lib_sha:
            if print_output:
                print(f"OK: baseline_manifest_sha256: {baseline_usr_sha}")
        else:
            fail = True
            if print_output:
                print(f"FAIL: baseline_manifest_sha_mismatch: {baseline_usr_sha} != {baseline_lib_sha}")

    try:
        audit = subprocess.run(["/usr/local/bin/eagevo-audit", "verify"], text=True, capture_output=True, check=False)
        if print_output:
            print(audit.stdout.strip())
        if audit.returncode == 0:
            if print_output:
                print("OK: audit_verify_green")
        else:
            fail = True
            if print_output:
                print("FAIL: audit_verify_failed")
                if audit.stderr:
                    print(audit.stderr.strip())
    except Exception as exc:
        fail = True
        if print_output:
            print(f"FAIL: audit_verify_exception: {exc}")

    for glob in FORBIDDEN_GLOBS:
        matches = list(Path("/").glob(glob.lstrip("/"))) if glob.startswith("/") else list(Path.home().glob("Library/LaunchAgents/*eagevo*"))
        if matches:
            fail = True
            if print_output:
                print(f"FAIL: unexpected_launchd_match: {glob}")
        else:
            if print_output:
                print(f"OK: absent: {glob}")

    if print_output:
        print()
        print("overall: GREEN" if not fail else "overall: RED")

    return 1 if fail else 0

def status(_args):
    rc = verify(print_output=True)
    if USR_INDEX.exists():
        data = load_index()
        print()
        print(f"components: {len(data.get('components', []))}")
        print(f"repo_head_short: {data.get('repository', {}).get('head_short')}")
    return rc

def show_index(_args):
    print(USR_INDEX.read_text(encoding="utf-8"), end="")
    return 0

def main():
    parser = argparse.ArgumentParser(prog="eagevo-control-plane")
    sub = parser.add_subparsers(dest="command")
    sub.add_parser("status")
    sub.add_parser("verify")
    sub.add_parser("index")
    args = parser.parse_args()

    if args.command in (None, "status"):
        return status(args)
    if args.command == "verify":
        return verify(print_output=True)
    if args.command == "index":
        return show_index(args)

    parser.print_help()
    return 2

if __name__ == "__main__":
    sys.exit(main())
